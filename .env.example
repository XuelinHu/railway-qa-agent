APP_ENV=development
AUTO_CREATE_TABLES=true

# PostgreSQL conversation storage.
# Replace <YOUR_PASSWORD> locally. Do not commit real credentials.
# If the password contains @, encode it as %40 inside DATABASE_URL.
POSTGRES_USER=deipss
POSTGRES_PASSWORD=<YOUR_PASSWORD>
POSTGRES_DB=railway_qa_agent
DATABASE_URL=postgresql+asyncpg://deipss:<YOUR_PASSWORD>@localhost:5432/railway_qa_agent

# Qdrant vector store.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=railway_knowledge
QDRANT_TIMEOUT_SECONDS=8
RAG_VECTOR_ENABLED=true

# LLM provider configuration. Keep this OpenAI-compatible where possible.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Embedding and reranking models.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=16
RERANKER_MODEL=

# Frontend.
VITE_API_BASE_URL=/api
